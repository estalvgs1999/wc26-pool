NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron authorization (set same value in Vercel dashboard → Environment Variables)
CRON_SECRET=your-random-secret-min-32-chars

# API-Football (https://www.api-football.com) — Basic plan or higher (100+ req/day)
API_FOOTBALL_KEY=your-api-football-key

# Local mock override — point the cron at the local mock API instead of api-football.com
# Uncomment for local testing, remove/leave empty in production
# API_FOOTBALL_BASE=http://localhost:3000/api/mock/football
