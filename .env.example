# ============================================================
# WC26 Prediction Pool — Variables de entorno (producción)
#
# Copia este archivo como .env.local para desarrollo o configura
# estas variables directamente en tu plataforma de despliegue.
#
# Obtener valores de Supabase:
#   Dashboard → Project Settings → API
# ============================================================


# ── Supabase ─────────────────────────────────────────────────

# URL pública del proyecto (expuesta al cliente)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Clave anon — solo permite operaciones permitidas por RLS (expuesta al cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave service role — bypasa RLS, SOLO usar en servidor
# Obtener en: Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── Aplicación ───────────────────────────────────────────────

# URL pública de la aplicación — usada en redirects de autenticación
# En Vercel: https://<tu-dominio>.vercel.app  o tu dominio personalizado
NEXT_PUBLIC_SITE_URL=https://wc26.example.com


# ── Cron ─────────────────────────────────────────────────────

# Secreto para autorizar el cron de sincronización de resultados
# Generar con: openssl rand -base64 32
# Debe coincidir con el header que envía Vercel Cron: Authorization: Bearer <valor>
CRON_SECRET=


# ── API-Football ─────────────────────────────────────────────

# Clave de API-Football (https://www.api-football.com)
# Plan mínimo requerido: Basic (100+ req/día)
# Obtener en: Dashboard → My Account → API Key
API_FOOTBALL_KEY=

# ⚠️  Solo para desarrollo local — NO configurar en producción
# Apunta el cron al mock local en lugar de api-football.com
# API_FOOTBALL_BASE=http://localhost:3000/api/mock/football
